# ============================================================
# 一汽奥迪 APP 自动任务系统 - 环境变量配置模板
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 切勿将 .env 提交到版本控制系统
# ============================================================

# ============================================================
# 数据库配置 (MySQL)
# ============================================================
# 本地开发环境（使用宿主机 IP）
# MYSQL_HOST=192.168.50.50
# MYSQL_PORT=3306

# 生产环境（使用 Docker 容器名）
# MYSQL_HOST=mysql
# MYSQL_PORT=3306

# 通用配置
MYSQL_USER=yqad_user
MYSQL_PASSWORD=your_secure_mysql_password
MYSQL_DATABASE=yqad_db

# 注意：
# - NODE_ENV=production 时默认使用 mysql:3306
# - NODE_ENV=development 时默认使用 192.168.50.50:3306
# - 本地开发和生产环境应使用不同的数据库名称以隔离数据

# ============================================================
# Redis 配置
# ============================================================
# 本地开发环境（使用宿主机 IP）
# REDIS_HOST=192.168.50.50
# REDIS_PORT=6379

# 生产环境（使用 Docker 容器名）
# REDIS_HOST=redis
# REDIS_PORT=6379

# 通用配置
REDIS_PASSWORD=
REDIS_DB=0

# Key 前缀（用于隔离不同环境的数据）
# 本地开发：REDIS_PREFIX=dev:
# 生产环境：REDIS_PREFIX=prod:
REDIS_PREFIX=dev:

# 注意：
# - NODE_ENV=production 时默认使用 redis:6379
# - NODE_ENV=development 时默认使用 192.168.50.50:6379
# - 使用不同的 REDIS_PREFIX 可以隔离本地和生产数据

# ============================================================
# ChromaDB 配置（向量数据库）
# ============================================================
# 本地开发环境（使用宿主机 IP）
# CHROMADB_URL=http://192.168.50.50:8000

# 生产环境（使用 Docker 容器名）
# CHROMADB_URL=http://chromadb:8000

# 或者分开配置
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# 注意：
# - 如果同时设置了 CHROMADB_URL 和 CHROMADB_HOST/PORT，CHROMADB_URL 优先
# - 本地开发使用 IP 通信：http://192.168.50.50:8000
# - 生产环境使用容器名通信：http://chromadb:8000
# - NODE_ENV=production 时默认使用 http://chromadb:8000
# - NODE_ENV=development 时默认使用 http://192.168.50.50:8000

# ============================================================
# AI Provider 配置
# ============================================================
# Provider 1 (主力)
AI_PROVIDER_1_NAME=provider1
AI_PROVIDER_1_API_KEY=your_api_key_1
AI_PROVIDER_1_BASE_URL=https://api.provider1.com
AI_PROVIDER_1_MODEL=model-name-1

# Provider 2 (备用)
AI_PROVIDER_2_NAME=provider2
AI_PROVIDER_2_API_KEY=your_api_key_2
AI_PROVIDER_2_BASE_URL=https://api.provider2.com
AI_PROVIDER_2_MODEL=model-name-2

# ============================================================
# AI 兜底机制配置
# ============================================================
AI_FALLBACK_ENABLED=true
AI_FALLBACK_MODE=robust
AI_FALLBACK_MAX_RETRIES=2
AI_FALLBACK_BASE_DELAY=2000
AI_FALLBACK_MAX_DELAY=10000

# ============================================================
# 认证配置
# ============================================================
# Session 密钥（建议使用 openssl rand -hex 32 生成）
SESSION_SECRET=your_session_secret_key_here

# API Token（可选，也可以通过 Redis 初始化脚本生成）
# API_TOKEN=

# ============================================================
# 服务器配置
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# 车辆监控配置（可选）
# ============================================================
VEHICLE_MONITOR_ENABLED=false
# VEHICLE_MONITOR_TOKEN=your_vehicle_token

# ============================================================
# Home Assistant 集成（可选）
# ============================================================
# HA_BASE_URL=
# HA_TOKEN=

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=info
LOG_DIR=./logs

# ============================================================
# 其他配置
# ============================================================
# 管理员密码（仅首次初始化时使用）
# ADMIN_PASSWORD=admin123
