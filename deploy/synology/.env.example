# ============================================================
# 一汽奥迪 APP 自动任务系统 - 生产环境变量配置
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际需求修改配置值
# 3. 切勿将 .env 提交到版本控制系统
# ============================================================

# ============================================================
# MySQL 数据库配置
# ============================================================
# 注意：生产环境数据库名称为 yqad_prod_db，与测试环境（yqad_db）隔离
MYSQL_ROOT_PASSWORD=Yqad@2026Secure
MYSQL_DATABASE=yqad_prod_db

# ============================================================
# Redis 缓存配置
# ============================================================
# 生产环境使用 DB 1，Key 前缀 prod:（与测试环境隔离）
# 无需额外配置，已在 docker-compose.yml 中设置

# ============================================================
# ChromaDB 向量数据库配置
# ============================================================
# 生产环境 Collection 前缀：prod:（与测试环境隔离）
# 无需额外配置，已在 docker-compose.yml 中设置

# ============================================================
# 应用配置
# ============================================================
# Web 访问端口（宿主机端口）
YQAD_PORT=3000

# Session 密钥（建议使用 openssl rand -hex 32 生成）
# 生成命令：openssl rand -hex 32
SESSION_SECRET=random-secret-key-yqad-auto-tasks

# 日志级别：info | warn | error | debug
LOG_LEVEL=info

# ============================================================
# 时区配置
# ============================================================
TZ=Asia/Shanghai
