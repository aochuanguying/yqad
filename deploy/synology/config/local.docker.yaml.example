auth:
  username: "your_phone"
  password: "your_password"

ai:
  providers:
    - name: "openai"
      apiKey: "your-api-key"
      baseUrl: "https://api.openai.com/v1"
      model: "gpt-4.1"
      temperature: 0.7
      maxTokens: 2000

web:
  baseUrl: "http://your-nas-ip:3000"

materials:
  rawPath: "./data/materials/raw"
  processedPath: "./data/materials/processed"
  processing:
    outputFormat: "jpeg"
    jpegQuality: 82
    maxFilesPerRun: 500
    heicFallback:
      enabled: true
      command: "heif-convert"
      timeoutMs: 30000
