{
  "info": {
    "name": "远程发帖 API",
    "description": "远程发帖 API 允许手机端通过 HTTP 接口获取发帖内容，然后由手机端模拟人工发布到社区",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "api_token",
      "value": "your-token-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "单篇生成",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"useTopic\": true,\n  \"mode\": \"featured\",\n  \"topicId\": \"\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/generate",
          "host": ["{{base_url}}"],
          "path": ["posts", "generate"]
        },
        "description": "生成单篇发帖内容"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"生成成功\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test(\"验证响应数据结构\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('title');",
              "    pm.expect(jsonData.data).to.have.property('content');",
              "    pm.expect(jsonData.data).to.have.property('images');",
              "    pm.expect(jsonData.data).to.have.property('mode');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "批量生成",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"count\": 3,\n  \"useTopic\": true,\n  \"mode\": \"featured\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/batch",
          "host": ["{{base_url}}"],
          "path": ["posts", "batch"]
        },
        "description": "批量生成发帖内容，返回任务 ID 用于查询进度"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"批量生成成功\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData).to.have.property('taskId');",
              "});",
              "",
              "// 保存 taskId 到环境变量，用于后续查询",
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"current_task_id\", jsonData.taskId);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "查询任务状态",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/tasks/{{current_task_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "tasks", "{{current_task_id}}"]
        },
        "description": "查询批量生成任务的执行状态"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"状态码为 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"任务状态正确\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.expect(jsonData).to.have.property('progress');",
              "});",
              "",
              "// 如果任务完成，验证结果数据",
              "var jsonData = pm.response.json();",
              "if (jsonData.status === 'completed') {",
              "    pm.test(\"任务已完成\", function () {",
              "        pm.expect(jsonData).to.have.property('results');",
              "        pm.expect(jsonData.results.length).to.equal(jsonData.progress.total);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "普通模式单篇生成",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"useTopic\": true,\n  \"mode\": \"normal\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/generate",
          "host": ["{{base_url}}"],
          "path": ["posts", "generate"]
        },
        "description": "使用普通模式生成单篇发帖内容"
      }
    },
    {
      "name": "不使用主题生成",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"useTopic\": false,\n  \"mode\": \"featured\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/generate",
          "host": ["{{base_url}}"],
          "path": ["posts", "generate"]
        },
        "description": "不使用预配置主题生成发帖内容"
      }
    },
    {
      "name": "指定主题生成",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"useTopic\": true,\n  \"mode\": \"featured\",\n  \"topicId\": \"abc123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/generate",
          "host": ["{{base_url}}"],
          "path": ["posts", "generate"]
        },
        "description": "指定特定主题 ID 生成发帖内容"
      }
    },
    {
      "name": "批量生成 5 篇",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"count\": 5,\n  \"useTopic\": true,\n  \"mode\": \"normal\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/batch",
          "host": ["{{base_url}}"],
          "path": ["posts", "batch"]
        },
        "description": "批量生成 5 篇普通模式的发帖内容"
      }
    }
  ]
}
