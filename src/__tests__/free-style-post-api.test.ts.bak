/**
 * 自由发帖 API 测试 - 直接调用 API 执行发帖
 * 测试自由发帖模式的完整流程：互联网参考 → AI 改写 → 合规检查 → 发布
 */

import { AutoPostService } from '../services/auto-post';
import { RealAudiApi } from '../api/real-client';
import { AuthService } from '../services/auth';
import { getAllTopics } from '../web/services/topics-service';
import { getLogger } from '../utils/logger';

const logger = getLogger('free-style-post-api-test');

describe('Free Style Post API', () => {
  let api: RealAudiApi;
  let authService: AuthService;
  let postService: AutoPostService;

  beforeAll(async () => {
    // 初始化 API 和认证服务
    api = new RealAudiApi();
    authService = await AuthService.create(api);
    postService = new AutoPostService(api, authService);
    
    logger.info('测试初始化完成');
  });

  afterAll(() => {
    logger.info('测试结束');
  });

  /**
   * 测试 1: 自由发帖模式（互联网参考）
   * 直接调用 postFreeStyle 方法执行发帖
   */
  describe('postFreeStyle - 自由发帖模式', () => {
    it('应该成功执行自由发帖（互联网参考模式）', async () => {
      // 模拟无可用主题的场景，触发自由发帖
      const result = await postService.performDailyPosts(1, 'normal', true);
      
      // 验证结果
      expect(result).toBeDefined();
      expect(Array.isArray(result)).toBe(true);
      expect(result.length).toBe(1);
      
      const postResult = result[0];
      logger.info(`自由发帖结果：${JSON.stringify(postResult, null, 2)}`);
      
      // 发帖应该成功（或者至少完成流程）
      expect(postResult.success).toBe(true);
      expect(postResult.source).toBe('free');
      expect(postResult.title).toBeDefined();
      expect(postResult.postId).toBeDefined();
      
      logger.info(`✓ 自由发帖成功：${postResult.title}`);
    }, 120000); // 2 分钟超时

    it('应该支持精华帖模式的自由发帖', async () => {
      const result = await postService.performDailyPosts(1, 'featured', true);
      
      expect(result).toBeDefined();
      expect(result.length).toBe(1);
      
      const postResult = result[0];
      logger.info(`精华自由发帖结果：${JSON.stringify(postResult, null, 2)}`);
      
      // 验证发帖结果
      expect(postResult.success).toBe(true);
      expect(postResult.mode).toBeDefined();
      
      logger.info(`✓ 精华自由发帖成功：${postResult.title}`);
    }, 120000);
  });

  /**
   * 测试 2: 直接调用互联网参考模式
   * 测试互联网参考素材获取和 AI 改写流程
   */
  describe('tryInternetReferenceMode - 互联网参考模式', () => {
    it('应该成功获取互联网参考素材并生成内容', async () => {
      // 使用反射调用私有方法（测试用）
      const tryInternetReferenceMode = (postService as any).tryInternetReferenceMode.bind(postService);
      
      const result = await tryInternetReferenceMode('normal', 'manual');
      
      logger.info(`互联网参考模式结果：${JSON.stringify(result, null, 2)}`);
      
      // 验证结果
      expect(result).toBeDefined();
      expect(result.success).toBe(true);
      expect(result.source).toBe('free');
      expect(result.title).toBeDefined();
      expect(result.content).toBeDefined();
      
      logger.info(`✓ 互联网参考模式发帖成功：${result.title}`);
    }, 120000);
  });

  /**
   * 测试 3: 完整发帖流程（包含所有中间步骤）
   * 验证从内容生成到发布的完整链路
   */
  describe('performDailyPosts - 完整发帖流程', () => {
    it('应该执行完整的自由发帖流程（无主题场景）', async () => {
      // 获取所有主题，确认当前主题状态
      const allTopics = await getAllTopics();
      const availableTopics = allTopics.filter(t => t.status === 'unused');
      
      logger.info(`当前可用主题数量：${availableTopics.length}`);
      
      // 如果没有任何主题，会触发自由发帖
      // 如果有主题，会先使用主题发帖
      
      const result = await postService.performDailyPosts(1, 'normal', true);
      
      expect(result).toBeDefined();
      expect(result.length).toBe(1);
      
      const postResult = result[0];
      logger.info(`完整发帖流程结果：${JSON.stringify(postResult, null, 2)}`);
      
      // 验证发帖成功
      expect(postResult.success).toBe(true);
      expect(postResult.postId).toBeDefined();
      expect(postResult.title).toBeDefined();
      
      logger.info(`✓ 完整发帖流程执行成功`);
    }, 120000);
  });

  /**
   * 测试 4: 并发控制测试
   * 验证发帖任务的并发控制机制
   */
  describe('Concurrency Control - 并发控制', () => {
    it('应该阻止并发发帖请求', async () => {
      // 同时发起两个发帖请求
      const promise1 = postService.performDailyPosts(1, 'normal', true);
      const promise2 = postService.performDailyPosts(1, 'normal', true);
      
      const results = await Promise.allSettled([promise1, promise2]);
      
      // 至少有一个应该成功
      const successCount = results.filter(r => r.status === 'fulfilled').length;
      expect(successCount).toBeGreaterThanOrEqual(1);
      
      // 检查是否有被拒绝的请求（并发控制）
      const rejectedCount = results.filter(r => r.status === 'rejected').length;
      
      logger.info(`并发测试结果：成功 ${successCount} 个，拒绝 ${rejectedCount} 个`);
    }, 120000);
  });

  /**
   * 测试 5: 错误处理和降级
   * 测试在各种异常情况下的降级处理
   */
  describe('Error Handling and Fallback - 错误处理', () => {
    it('应该处理互联网参考查询失败的情况', async () => {
      // 这个测试需要 mock 互联网参考服务
      // 暂时跳过，等待更完善的 mock 实现
      logger.warn('跳过：需要 mock 互联网参考服务');
    });

    it('应该处理图片上传失败的情况', async () => {
      // 这个测试需要 mock 图片上传服务
      // 暂时跳过，等待更完善的 mock 实现
      logger.warn('跳过：需要 mock 图片上传服务');
    });
  });

  /**
   * 测试 6: 发帖日志记录
   * 验证发帖日志是否正确记录
   */
  describe('Post Logging - 发帖日志', () => {
    it('应该记录自由发帖的成功日志', async () => {
      const result = await postService.performDailyPosts(1, 'normal', true);
      
      expect(result.length).toBe(1);
      expect(result[0].success).toBe(true);
      
      // 验证日志记录（需要访问数据库）
      const { postLoggingService } = await import('../services/post-logging-service');
      
      // 查询最近的日志
      const logs = await postLoggingService.query({
        page: 1,
        limit: 1,
        postType: 'free',
      });
      
      expect(logs).toBeDefined();
      expect(logs.logs.length).toBeGreaterThan(0);
      
      logger.info(`✓ 发帖日志记录成功，共 ${logs.logs.length} 条`);
    }, 120000);
  });
});

/**
 * 独立测试：直接调用 API 接口
 * 模拟真实场景下的 API 调用
 */
describe('Direct API Call - 直接 API 调用', () => {
  it('应该通过 HTTP API 触发自由发帖', async () => {
    // 这个测试需要启动 HTTP 服务器
    // 暂时跳过，等待集成测试环境
    logger.warn('跳过：需要启动 HTTP 服务器');
  });
});
